-- [[ Logic ]]
local BangActive, OrbitActive, Target = false, false, nil
local BAngle, OAngle = 0, 0

local function GetTarget()
    local text = Input.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) and p ~= LP then return p end
    end
    return nil
end

BangBtn.MouseButton1Click:Connect(function()
    Target = GetTarget()
    if not Target then return end
    BangActive = not BangActive
    BangBtn.Text = BangActive and "BANG: ON" or "BANG: OFF"
    BangBtn.BackgroundColor3 = BangActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80, 0, 0)
    Camera.CameraSubject = (BangActive or OrbitActive) and Target.Character.Humanoid or LP.Character.Humanoid
end)

OrbitBtn.MouseButton1Click:Connect(function()
    Target = GetTarget()
    if not Target then return end
    OrbitActive = not OrbitActive
    OrbitBtn.Text = OrbitActive and "ORBIT: ON" or "ORBIT: OFF"
    OrbitBtn.BackgroundColor3 = OrbitActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80, 0, 0)
    Camera.CameraSubject = (BangActive or OrbitActive) and Target.Character.Humanoid or LP.Character.Humanoid
end)

RunService.Heartbeat:Connect(function(dt)
    if (BangActive or OrbitActive) and Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
        local MyRoot = LP.Character:FindFirstChild("HumanoidRootPart")
        local T_Root = Target.Character.HumanoidRootPart
        if MyRoot then
            local bSpd = tonumber(BangSpeed.Text) or 35
            local oSpd = tonumber(OrbitSpeed.Text) or 5
            local dist = tonumber(DistInput.Text) or 1.5
            
            BAngle = BAngle + (bSpd * dt)
            OAngle = OAngle + (oSpd * dt)
            
            local Motion = BangActive and math.sin(BAngle) * 0.8 or 0
            
            if OrbitActive then
                -- ئەگەر ئۆربیت کار بکەت: دزەڤریت (دگەل لێدانێ ئەگەر پێ بیت)
                local cosX = math.cos(OAngle) * (dist + Motion)
                local sinZ = math.sin(OAngle) * (dist + Motion)
                MyRoot.CFrame = CFrame.new(T_Root.Position + Vector3.new(cosX, 0, sinZ), T_Root.Position)
            else
                -- ئەگەر ب تنێ بانگ بیت: ل پشت دمینیت و لێدەت
                MyRoot.CFrame = T_Root.CFrame * CFrame.new(0, 0, dist + Motion)
            end
        end
    end
end)
