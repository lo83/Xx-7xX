-- [[ Logic ]]
local Banging, Orbiting, Target, Angle = false, false, nil, 0

local function GetT()
    local text = Input.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) and p ~= LP then return p end
    end
    return nil
end

BangBtn.MouseButton1Click:Connect(function()
    Target = GetT()
    if not Target then return end
    Banging = not Banging
    BangBtn.BackgroundColor3 = Banging and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(120, 0, 0)
    Camera.CameraSubject = Banging and Target.Character.Humanoid or LP.Character.Humanoid
end)

OrbitBtn.MouseButton1Click:Connect(function()
    Target = GetT()
    if not Target then return end
    Orbiting = not Orbiting
    OrbitBtn.BackgroundColor3 = Orbiting and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(120, 0, 0)
end)

RunService.Heartbeat:Connect(function(dt)
    if (Banging or Orbiting) and Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
        local MyRoot = LP.Character:FindFirstChild("HumanoidRootPart")
        local T_Root = Target.Character.HumanoidRootPart
        if MyRoot then
            Angle = Angle + ((tonumber(SpeedInput.Text) or 45) * dt)
            local CF = T_Root.CFrame
            if Orbiting then CF = CF * CFrame.Angles(0, Angle, 0) * CFrame.new(0, 0, 3) end
            if Banging then
                local M = math.sin(Angle) * 1.8
                CF = Orbiting and CF * CFrame.new(0, 0, M) or CF * CFrame.new(0, 0, 1.2 + M)
            end
            MyRoot.CFrame = CFrame.new(CF.Position, T_Root.Position)
        end
    end
end)
