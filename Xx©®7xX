-- [[ Logic ]]
local Mode = "None"
local Target = nil
local BAngle, OAngle = 0, 0

local function GetTarget()
    local text = Input.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) and p ~= LP then return p end
    end
end

local function UpdateButtons()
    QonenBtn.Text = "qonen playere: " .. (Mode == "Qonen" and "ON" or "OFF")
    QonenBtn.BackgroundColor3 = (Mode == "Qonen" and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80, 0, 0))
    DaveBtn.Text = "dave da: " .. (Mode == "Dave" and "ON" or "OFF")
    DaveBtn.BackgroundColor3 = (Mode == "Dave" and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80, 0, 0))
    OrbitBtn.Text = "ldor player zvrin: " .. (Mode == "Orbit" and "ON" or "OFF")
    OrbitBtn.BackgroundColor3 = (Mode == "Orbit" and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80, 0, 0))
    KillBtn.Text = "koshtna yaryzana: " .. (Mode == "Kill" and "ON" or "OFF")
    KillBtn.BackgroundColor3 = (Mode == "Kill" and Color3.fromRGB(255, 80, 0) or Color3.fromRGB(150, 0, 0))
end

QonenBtn.MouseButton1Click:Connect(function() Target = GetTarget(); Mode = (Mode == "Qonen" and "None" or "Qonen"); UpdateButtons() end)
DaveBtn.MouseButton1Click:Connect(function() Target = GetTarget(); Mode = (Mode == "Dave" and "None" or "Dave"); UpdateButtons() end)
OrbitBtn.MouseButton1Click:Connect(function() Target = GetTarget(); Mode = (Mode == "Orbit" and "None" or "Orbit"); UpdateButtons() end)
KillBtn.MouseButton1Click:Connect(function() Target = GetTarget(); Mode = (Mode == "Kill" and "None" or "Kill"); UpdateButtons() end)

RunService.Heartbeat:Connect(function(dt)
    if Mode ~= "None" and Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
        local MyRoot = LP.Character:FindFirstChild("HumanoidRootPart")
        local T_Root = Target.Character.HumanoidRootPart
        if MyRoot then
            BAngle = BAngle + ((tonumber(BangSpeed.Text) or 35) * dt)
            OAngle = OAngle + ((tonumber(OrbitSpeedInput.Text) or 5) * dt)
            
            if Mode == "Qonen" then
                MyRoot.CFrame = T_Root.CFrame * CFrame.new(0, 0, 1.5 + math.sin(BAngle) * 0.8)
            elseif Mode == "Dave" then
                MyRoot.CFrame = T_Root.CFrame * CFrame.new(0, 0.8, -1.2 + math.sin(BAngle) * 0.8) * CFrame.Angles(0, math.pi, 0)
            elseif Mode == "Orbit" then
                MyRoot.CFrame = CFrame.new(T_Root.Position + Vector3.new(math.cos(OAngle)*2.5, 0, math.sin(OAngle)*2.5), T_Root.Position)
            elseif Mode == "Kill" then
                local FlingAngle = tick() * 50 
                MyRoot.Velocity = Vector3.new(500, 500, 500)
                MyRoot.CFrame = CFrame.new(T_Root.Position + Vector3.new(math.cos(FlingAngle)*1.5, 0, math.sin(FlingAngle)*1.5), T_Root.Position)
            end
        end
    end
end)

