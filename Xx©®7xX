-- [[ Logic ]]
local Banging = false
local Orbiting = false
local Target = nil
local Angle = 0

local function FindT()
    local text = Input.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) and p ~= LP then
            return p
        end
    end
    return nil
end

BangBtn.MouseButton1Click:Connect(function()
    Target = FindT()
    if not Target then Status.Text = "نەهاتە دیتن!" return end
    Banging = not Banging
    if Banging then
        BangBtn.Text = "BANG + VIEW (ON)"
        BangBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        Camera.CameraSubject = Target.Character:FindFirstChild("Humanoid")
    else
        BangBtn.Text = "BANG + VIEW (OFF)"
        BangBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
        Camera.CameraSubject = LP.Character:FindFirstChild("Humanoid")
    end
end)

OrbitBtn.MouseButton1Click:Connect(function()
    Target = FindT()
    if not Target then Status.Text = "نەهاتە دیتن!" return end
    Orbiting = not Orbiting
    OrbitBtn.Text = Orbiting and "ORBIT (ON)" or "ORBIT (OFF)"
    OrbitBtn.BackgroundColor3 = Orbiting and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(100, 0, 0)
end)

RunService.Heartbeat:Connect(function(dt)
    if (Banging or Orbiting) and Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
        local MyRoot = LP.Character:FindFirstChild("HumanoidRootPart")
        local T_Root = Target.Character.HumanoidRootPart
        if MyRoot then
            local S = tonumber(SpeedInput.Text) or 45
            Angle = Angle + (S * dt)
            Status.Text = "Target: " .. Target.Name

            local FinalCF = T_Root.CFrame
            
            if Orbiting then
                FinalCF = T_Root.CFrame * CFrame.Angles(0, Angle, 0) * CFrame.new(0, 0, 3)
            end
            
            if Banging then
                local Motion = math.sin(Angle) * 2
                if not Orbiting then
                    FinalCF = T_Root.CFrame * CFrame.new(0, 0, 1.2 + Motion)
                else
                    FinalCF = FinalCF * CFrame.new(0, 0, Motion)
                end
            end
            
            MyRoot.CFrame = CFrame.new(FinalCF.Position, T_Root.Position)
        end
    end
end)

