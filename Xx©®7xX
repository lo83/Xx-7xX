SpeedInput.TextColor3 = Color3.fromRGB(0, 255, 0)

local OpenBtn = Instance.new("TextButton")
OpenBtn.Parent = ScreenGui
OpenBtn.Text = "Xx7"
OpenBtn.Size = UDim2.new(0, 45, 0, 45)
OpenBtn.Position = UDim2.new(0, 5, 0.5, 0)
OpenBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
OpenBtn.TextColor3 = Color3.fromRGB(255, 255, 0)
OpenBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)

-- [[ Logic ]]
local Banging, Target, Angle = false, nil, 0

local function GetT()
    local text = Input.Text:lower()
    if text == "" then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if (p.Name:lower():sub(1, #text) == text or p.DisplayName:lower():sub(1, #text) == text) and p ~= LP then return p end
    end
    return nil
end

BangBtn.MouseButton1Click:Connect(function()
    Target = GetT()
    if not Target then return end
    Banging = not Banging
    BangBtn.BackgroundColor3 = Banging and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(120, 0, 0)
    Camera.CameraSubject = Banging and Target.Character.Humanoid or LP.Character.Humanoid
end)

RunService.Heartbeat:Connect(function(dt)
    if Banging and Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") then
        local MyRoot = LP.Character:FindFirstChild("HumanoidRootPart")
        local T_Root = Target.Character.HumanoidRootPart
        if MyRoot then
            local speed = tonumber(SpeedInput.Text) or 35
            Angle = Angle + (speed * dt)
            
            -- لڤینا Bang بێی کو بچیتە دناڤ لاشێ ویدا
            -- 1.3 مەسافەیا پشتا وی یە (دشێی بکەی ٢ ئەگەر تە دڤێت دویرتر بیت)
            -- math.abs(math.sin) ناهێلیت بچیتە پێش، تنێ دزڤڕیتە پاش
            local Offset = 1.2 + (math.abs(math.sin(Angle)) * 0.8)
            
            MyRoot.CFrame = T_Root.CFrame * CFrame.new(0, 0, Offset)
        end
    end
end)
